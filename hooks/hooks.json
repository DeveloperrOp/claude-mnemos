{
  "hooks": {
    "PreCompact": [
      {
        "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/pre_compact.py",
        "timeout_seconds": 15,
        "blocking": false
      }
    ],
    "SessionEnd": [
      {
        "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/session_end.py",
        "timeout_seconds": 15,
        "blocking": false
      }
    ],
    "SessionStart": [
      {
        "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py",
        "timeout_seconds": 15,
        "blocking": true
      }
    ]
  }
}
